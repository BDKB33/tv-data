import ccxt
import pandas as pd
from datetime import datetime, timedelta, timezone
import time
import os

# ========================= CONFIG =========================
SYMBOLS = ['BTC/USDT', 'ETH/USDT', 'SOL/USDT', 'XRP/USDT', 'ADA/USDT', 'SUI/USDT']
# Define the 365-day period ending today (approx May 14, 2026)
END_DATE = datetime.now(timezone.utc).date()
START_DATE = END_DATE - timedelta(days=365)
OUTPUT_CSV = f'binance_high_low_times_365d.csv'

# =========================================================
# Initialize Binance with rate limit enabled
exchange = ccxt.binance({
    'enableRateLimit': True,
    'options': {'defaultType': 'spot'}
})

def get_1m_data_for_day(symbol, target_date):
    """Fetches 1m candles for a specific date and returns high/low times"""
    start_ts = int(datetime(target_date.year, target_date.month, target_date.day, tzinfo=timezone.utc).timestamp() * 1000)
    end_ts = start_ts + (24 * 60 * 60 * 1000) - 1
    
    all_1m = []
    current_since = start_ts
    
    # Fetch 1m data for the whole day (1440 minutes)
    while current_since < end_ts:
        try:
            # 1000 minutes is ~16 hours, sufficient for inner loop
            candles = exchange.fetch_ohlcv(symbol, timeframe='1m', since=current_since, limit=1000)
            if not candles or candles[0][0] >= end_ts:
                break
            all_1m.extend(candles)
            current_since = candles[-1][0] + 60000
            
            # Rate limit respect
            time.sleep(exchange.rateLimit / 1000) 
        except Exception as e:
            print(f"Error fetching 1m for {symbol} on {target_date}: {e}")
            time.sleep(20) # Longer sleep on error
            break

    if not all_1m:
        return None

    df_1m = pd.DataFrame(all_1m, columns=['timestamp', 'open', 'high', 'low', 'close', 'volume'])
    
    # Find exact times of max high and min low
    high_idx = df_1m['high'].idxmax()
    low_idx = df_1m['low'].idxmin()
    
    return {
        'symbol': symbol,
        'date': target_date,
        'day_high': df_1m['high'].max(),
        'high_time': pd.to_datetime(df_1m.loc[high_idx, 'timestamp'], unit='ms'),
        'day_low': df_1m['low'].min(),
        'low_time': pd.to_datetime(df_1m.loc[low_idx, 'timestamp'], unit='ms')
    }

# ========================= MAIN LOOP =========================
all_results = []

for symbol in SYMBOLS:
    print(f"Processing {symbol}...")
    # Generate list of days
    current_day = START_DATE
    while current_day < END_DATE:
        print(f"  Fetching 1m for {current_day}")
        daily_high_low = get_1m_data_for_day(symbol, current_day)
        if daily_high_low:
            all_results.append(daily_high_low)
        current_day += timedelta(days=1)
        # Small delay between days to avoid rate limits
        time.sleep(0.5) 

# Save to CSV
df_final = pd.DataFrame(all_results)
df_final.to_csv(OUTPUT_CSV, index=False)
print(f"Finished. Data saved to {OUTPUT_CSV}")
